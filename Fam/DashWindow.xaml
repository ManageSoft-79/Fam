                                                    </Grid>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Q3 ST" Width="75">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <TextBlock Text="{Binding BookedSt, StringFormat=N0}" TextAlignment="Right" />
                                                    </Grid>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="Q4 LT" Width="75">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <TextBlock Text="{Binding BookedLt, StringFormat=N0}" TextAlignment="Right" />
                                                    </Grid>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Q4 ST" Width="75">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <TextBlock Text="{Binding BookedSt, StringFormat=N0}" TextAlignment="Right" />
                                                    </Grid>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>-->

                                        <GridViewColumn Header="LT" Width="75">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <TextBlock TextAlignment="Right">
                                                            <TextBlock.Style>
                                                                <Style TargetType="{x:Type TextBlock}">
                                                                    <Setter Property="Text" Value="{Binding BookedLt, StringFormat=N0}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding BookedLt}" Value="0">
                                                                            <Setter Property="Text" Value="-" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="ST" Width="75">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <TextBlock TextAlignment="Right">
                                                            <TextBlock.Style>
                                                                <Style TargetType="{x:Type TextBlock}">
                                                                    <Setter Property="Text" Value="{Binding BookedSt, StringFormat=N0}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding BookedLt}" Value="0">
                                                                            <Setter Property="Text" Value="-" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>

                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <EventSetter Event="MouseDoubleClick" Handler="lviCapitalgains_MouseDoubleClick" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.GroupStyle>
                                    <StaticResource ResourceKey="group01" />
                                </ListView.GroupStyle>
                            </ListView>

                            <TextBlock Text="✶ Categories and capital gains are only informative. Refer official sources for accurate and final categories and figures." Margin="0,10,0,0" Grid.Row="3" />
                        </Grid>

                        <!--Chart-->
                        <Grid x:Name="gridChart" RowDefinitions="auto,*,auto" Margin="10" d:Visibility="Visible" Visibility="Collapsed">
                            
                            <UserControl Template="{StaticResource ResourceKey='commonrow'}" />

                            <lvc:PieChart Series="{Binding Categoryseries}" InitialRotation="-90" Background="Transparent" LegendPosition="Bottom" TooltipPosition="Hidden" LegendTextSize="12" Grid.Row="1" RenderOptions.BitmapScalingMode="NearestNeighbor" UseLayoutRounding="True" SnapsToDevicePixels="True" />
                        </Grid>

                        <!--Folios-->
                        <Grid x:Name="gridFolios" RowDefinitions="*,auto" ColumnDefinitions="*,250" Margin="10" d:Visibility="Collapsed">
                            <!--folios-->
                            <ListView x:Name="lvFolios" ItemsSource="{Binding Folios}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="AMC" Width="200" DisplayMemberBinding="{Binding Fundname}" />
                                        <GridViewColumn Header="Folio" Width="100" DisplayMemberBinding="{Binding Name}" />

                                        <GridViewColumn Header="Group" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox x:Name="cmbGroupname" ItemsSource="{Binding portfolio.Foliogroups}" SelectedItem="{Binding Group, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="Name" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="Current schemes" Width="300">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Funds}" TextWrapping="Wrap" FontWeight="Normal" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>

                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />

                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Isactive}" Value="True">
                                                <Setter Property="FontWeight" Value="DemiBold" />
                                                <Setter Property="Background" Value="WhiteSmoke" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>

                            <!--groups-->
                            <Grid RowDefinitions="auto,*" Grid.Column="1" Margin="10,0,0,0">

                                <Grid ColumnDefinitions="*,auto">
                                    <TextBlock Text="Folio groups" FontWeight="Bold" VerticalAlignment="Center" Padding="0,5" />
                                    <Button x:Name="butAddgroup" Content="Add" Grid.Column="1" Click="butAddgroup_Click" Width="50" />
                                </Grid>

                                <ItemsControl x:Name="lvGroups" ItemsSource="{Binding Foliogroups}" Grid.Row="1" Margin="0,10,0,0" BorderThickness="1" BorderBrush="Gray">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,auto" Grid.Row="1" Margin="5">
                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" MinWidth="75" VerticalContentAlignment="Center" />

                                                <Button x:Name="butDeletegroup" Click="butDeletegroup_Click" Content="Delete" Grid.Column="1" Margin="5,0,0,0" Width="60" Padding="2" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border Background="#DDDDDD" Grid.Row="2" CornerRadius="10" Margin="0,10,0,0">
                <Grid ColumnDefinitions="auto,*,auto" Margin="10">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="2">
                        <Button x:Name="butReloadfiles" Content="Reload files" Padding="15,5" Click="butReloadfiles_Click" Margin="0,0,10,0" />
                        <Button x:Name="butDownloadlinks" Content="Download links" Padding="15,5" Click="butDownloadlinks_Click" Margin="0,0,10,0" />

                        <Button x:Name="butRefresh" Content="Refresh" Padding="15,5" Click="butRefresh_Click" Margin="0,0,10,0" />
                        <Button x:Name="butClear" Content="Clear filter" ToolTip="Clear all applied filters" Padding="15,5" Click="butClear_Click" Margin="0,0,10,0" />
                        <Button x:Name="butCopy" Content="Copy" Padding="15,5" Click="butCopy_Click" Margin="0,0,10,0" />
                        <Button x:Name="butSave" Content="Save" Padding="15,5" Click="butSave_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

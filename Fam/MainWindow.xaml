<Window x:Class="Fam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fam"
        mc:Ignorable="d"
        Title="Fam" Height="600" Width="800" ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
    <Grid Background="#EEEEEE">
        <Grid Margin="10" Width="450" RowDefinitions="auto,*,auto">
            <Border Background="#053070" CornerRadius="10" >
                <StackPanel Margin="10">
                    <TextBlock Text="Fam" FontSize="28px" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Transactions Overview Tool" Margin="0,0,0,0" Foreground="WhiteSmoke"/>
                </StackPanel>
            </Border>
            <Border Background="White" Grid.Row="1" CornerRadius="10" Margin="0,10,0,0" >
                <ListView x:Name="lvRecents" Margin="5" BorderThickness="0" SelectionMode="Single">
                    <!--<ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>-->
                </ListView>
            </Border>

            <Border Grid.Row="2" CornerRadius="10" Background="#CCCCCC" Margin="0,10,0,0">
                <Grid RowDefinitions="*,*" ColumnDefinitions="*,*">
                    <Grid.Resources>
                        <Style TargetType="{x:Type Button}">
                            <Style.Setters>
                                <Setter Property="Height" Value="40"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="FontSize" Value="15px"/>
                            </Style.Setters>
                        </Style>
                    </Grid.Resources>
                    <Button x:Name="butNew" Content="New" FontWeight="Bold" Click="butNew_Click"/>
                    <Button x:Name="butOpen" Grid.Column="1" Content="Open" FontWeight="Bold" Click="butOpen_Click"/>
                    <Button x:Name="butDownloadlinks" Click="butDownloadlinks_Click" Grid.Row="1"  Content="Download links"/>
                    <Button x:Name="butSettings"  Grid.Row="1" Grid.Column="1" Content="Settings"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
